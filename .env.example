# Copy to .env and fill in. OpenPrism loads this from the repo root automatically.

# --- Backend: where panel calls go ---
# opencode -> RECOMMENDED. Piggyback a running opencode server: ALL its providers/
#             models, no keys here. Add providers in opencode (`opencode auth login`).
# direct   -> OpenPrism's own providers below (+ providers.json). Use if you don't run opencode.
OPENPRISM_BACKEND=opencode

# --- opencode backend (only when OPENPRISM_BACKEND=opencode) ---
# Leave defaults and OpenPrism spawns `opencode serve` itself, reusing your opencode auth.
# OPENPRISM_OPENCODE_URL=http://127.0.0.1:4096
# OPENPRISM_OPENCODE_PORT=4096
# OPENPRISM_OPENCODE_AUTOSERVE=1
# OPENCODE_SERVER_PASSWORD=

# --- direct backend: default provider (Alibaba Coding Plan shown as an example) ---
ALIBABA_API_KEY=sk-your-key-here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Add more OpenAI-compatible providers in providers.json (see providers.json.example).
# Which configured provider a bare (no-slash) model id resolves to:
OPENPRISM_DEFAULT_PROVIDER=alibaba

# --- Default panel (optional) ---
# Pin the default panel used when no per-call panel is given. Preset name, or a
# comma-separated list of model refs (opencode: provider/model). Per-call wins.
# OPENPRISM_PANEL=google/gemini-2.5-pro,openai/gpt-5.4,anthropic/claude-sonnet-4-6

# --- Panel tools (opencode backend) ---
# research -> web + read-only (default) | none -> no tools | all -> every tool incl. bash (DANGER)
OPENPRISM_PANEL_TOOLS=research

# --- Diversity / degradation ---
# Min distinct model FAMILIES for a non-degraded run; STRICT refuses below it.
OPENPRISM_MIN_FAMILIES=2
OPENPRISM_STRICT=0
# OPENPRISM_MAX_PANEL=8   # hard cap on panel size

# --- Judge ---
# claude-code   -> `claude -p` (flat-rate Claude Max plan) [default]; OPENPRISM_JUDGE_MODEL = alias e.g. opus
# anthropic-api -> ANTHROPIC_API_KEY (metered);                       OPENPRISM_JUDGE_MODEL = opus or model id
# opencode      -> route judge through opencode;                      OPENPRISM_JUDGE_MODEL = provider/model ref
OPENPRISM_JUDGE_BACKEND=claude-code
OPENPRISM_JUDGE_MODEL=opus
ANTHROPIC_API_KEY=

# --- Tuning ---
OPENPRISM_PANEL_TIMEOUT=300
OPENPRISM_MAX_TOKENS=8000
