{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openprism": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/ba1lly/OpenPrism", "openprism-mcp"],
      "enabled": true,
      "environment": {
        "OPENPRISM_BACKEND": "opencode",
        "OPENPRISM_JUDGE_BACKEND": "opencode",
        "OPENPRISM_JUDGE_MODEL": "anthropic/claude-opus-4-7"
      }
    }
  }
}
