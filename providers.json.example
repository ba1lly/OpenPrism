{
  "_comment": "Copy to providers.json to add extra OpenAI-compatible providers to the DIRECT backend. The Alibaba provider from .env is always included. api_key 'env:VAR' reads from the environment; or paste a literal key. Reference models in a panel as provider/model, e.g. openrouter/anthropic/claude-opus-4.",
  "openrouter": {
    "base_url": "https://openrouter.ai/api/v1",
    "api_key": "env:OPENROUTER_API_KEY",
    "models": ["anthropic/claude-opus-4", "google/gemini-2.5-pro", "deepseek/deepseek-chat"]
  },
  "deepseek": {
    "base_url": "https://api.deepseek.com/v1",
    "api_key": "env:DEEPSEEK_API_KEY",
    "models": ["deepseek-chat", "deepseek-reasoner"]
  }
}
